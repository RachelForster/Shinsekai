[run]
branch = True
source =
    asr
    config
    core
    frontend_bridge_core
    i18n
    live
    llm
    scripts
    sdk
    t2i
    tools
    tts
    ui
omit =
    test/*
    asr/asr_test.py
    live/danmuku_test.py
    ui/settings_ui/modules/resources_rc.py
    ui/settings_ui/modules/ui_main.py
    **/__pycache__/*
    **/*.pyc

[report]
precision = 2
show_missing = True
skip_empty = True
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    if TYPE_CHECKING:

[html]
directory = coverage/python/html

[xml]
output = coverage/python/coverage.xml

[json]
output = coverage/python/coverage.json
