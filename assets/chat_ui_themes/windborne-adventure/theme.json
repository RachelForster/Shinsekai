{
  "$schema": "../theme.schema.json",
  "schema": 1,
  "id": "windborne-adventure",
  "name": {
    "zh_CN": "风旅冒险",
    "en": "Windborne Adventure",
    "ja": "風渡りアドベンチャー"
  },
  "author": "Shinsekai",
  "version": "1.0.0",
