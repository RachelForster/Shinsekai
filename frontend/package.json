{
  "name": "shinsekai-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "vite",
    "dev:bridge": "python ../frontend_bridge.py --project-root ..",
    "dev:bridge:conda": "conda run -n shinsekai python ../frontend_bridge.py --project-root ..",
    "serve:bundle": "python ../webui_react.py",
    "serve:bundle:conda": "conda run -n shinsekai python ../webui_react.py",
    "build": "tsc -b && vite build",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "preview": "vite preview",
    "test": "vitest run",
    "test:functional": "playwright test e2e/functionality.spec.ts",
    "test:visual": "playwright test e2e/visual.spec.ts",
    "test:visual:update": "playwright test e2e/visual.spec.ts --update-snapshots",
    "test:watch": "vitest",
    "lint:types": "tsc -b --pretty false"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.80.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^15.0.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.5"
  }
}
