{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shinsekai",
  "version": "../package.json",
  "identifier": "icu.end0rph1n.shinsekai",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "pnpm build && pnpm prepare:tauri-resources"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "resources/": ""
    }
  }
}
